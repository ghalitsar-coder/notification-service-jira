# Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=8081

# Database Configuration (SQLite)
DB_PATH=./data/notifications.db

# Message Broker (RabbitMQ) Configuration
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
NOTIFICATION_EXCHANGE=notification_events
NOTIFICATION_QUEUE=notification_queue

# JWT Configuration
# Referencing JWT_SECRET from main backend todo-app-v2
JWT_SECRET=FL2Hr7ShZ+EKNsuHX8aoqeUFFSGVic9l+QJMnt1u3buyD23IqWtt+yyB2N6L5WAQv7TTlU7YTXlzAjpXdazs/Q==
# Allows bypassing JWT in local development for testing purposes by parsing simple ID headers if needed
ALLOW_INSECURE_USER_ID=false
